{
  "name": "online-food-ordering",
  "version": "1.0.0",
  "description": "Online Food Ordering System - Node.js, Express, MySQL, Sequelize, EJS, Bootstrap",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
