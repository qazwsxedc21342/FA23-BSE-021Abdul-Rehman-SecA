<div class="d-flex justify-content-between align-items-center mb-3">
  <h2>Menu Items</h2>
  <a href="/menu-items/new" class="btn btn-primary">Add Menu Item</a>
</div>

<div class="row">
  <% if (items.length === 0) { %>
  <div class="col-12">
    <p class="text-muted">No menu items available. Add one to get started.</p>
  </div>
  <% } %>

  <% items.forEach(function (item) { %>
  <div class="col-sm-12 col-md-6 col-lg-4 mb-4">
    <div class="card h-100 shadow-sm">
      <div class="card-body d-flex flex-column">
        <h5 class="card-title"><%= item.name %></h5>
        <h6 class="card-subtitle mb-2 text-muted">
          <%= item.category || 'Uncategorized' %>
        </h6>
        <p class="card-text flex-grow-1">
          <%= item.description || 'No description provided.' %>
        </p>
        <p class="fw-bold mb-1">$<%= item.price %></p>
        <p>
          <span
            class="badge <%= item.isAvailable ? 'bg-success' : 'bg-secondary' %>"
          >
            <%= item.isAvailable ? 'Available' : 'Unavailable' %>
          </span>
        </p>
        <div class="mt-2 d-flex justify-content-between">
          <a href="/menu-items/<%= item.id %>" class="btn btn-sm btn-outline-primary"
            >View</a
          >
          <a href="/menu-items/<%= item.id %>/edit" class="btn btn-sm btn-warning"
            >Edit</a
          >
          <form
            action="/menu-items/<%= item.id %>?_method=DELETE"
            method="POST"
            onsubmit="return confirm('Delete this item?');"
          >
            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
          </form>
        </div>
      </div>
    </div>
  </div>
  <% }) %>
</div>

